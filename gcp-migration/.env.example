# Cible GCP non secrète. Charger explicitement ce fichier dans le shell.
GCP_PROJECT_ID=devpod-gpu-exploration
GCP_REGION=europe-west4
GCP_ZONE=europe-west4-a
GCP_INSTANCE_NAME=ehgp-blackwell-spot

# Coupe-circuit de la VM Spot.
GCP_MAX_RUN_DURATION=8h

# Valeur historique avec IP externe. Pour une cible privée, fournir une
# interface compatible avec le VPC puis se connecter avec IAP/OS Login.
GCP_NETWORK_INTERFACE=network=default,access-config-type=ONE_TO_ONE_NAT,nic-type=GVNIC

# Laisser vide pour n'attacher aucun compte de service à la VM.
GCP_RUNTIME_SERVICE_ACCOUNT=
