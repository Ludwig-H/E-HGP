+struct ClosedAabbF32
+{
+    std::array<float, 3> lower;
+    std::array<float, 3> upper;
+};
+
+inline ClosedAabbF32 validate_closed_aabb_f32(torch::Tensor bounds_in)
+{
+    TORCH_CHECK(bounds_in.defined(), "bounds must be a defined torch.Tensor");
+    TORCH_CHECK(bounds_in.device().type() == at::kCPU, "bounds must be on the CPU");
+    TORCH_CHECK(bounds_in.scalar_type() == at::kFloat, "bounds must have dtype torch.float32");
+    TORCH_CHECK(bounds_in.dim() == 2 && bounds_in.size(0) == 2 && bounds_in.size(1) == 3,
+                "bounds must have shape (2, 3)");
+
+    torch::Tensor bounds = bounds_in.contiguous();
+    const float *values = bounds.data_ptr<float>();
+    ClosedAabbF32 result;
+    for (int axis = 0; axis < 3; ++axis)
+    {
+        const float lower = values[axis];
+        const float upper = values[3 + axis];
+        TORCH_CHECK(std::isfinite(lower) && std::isfinite(upper), "bounds must contain only finite values");
+        TORCH_CHECK(lower < upper, "bounds lower coordinates must be strictly below upper coordinates");
+        result.lower[axis] = lower;
+        result.upper[axis] = upper;
+    }
+    return result;
+}
+
